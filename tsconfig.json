{
  // Nuxt's generated tsconfig supplies includes + auto-import globals;
  // overriding `include` here would drop them, so only extend + tighten.
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "exclude": ["design", "node_modules", "dist", ".output"]
}
