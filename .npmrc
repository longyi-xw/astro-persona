# Flatten node_modules so Nitro's prerender bundle can resolve hoisted transitive
# deps (e.g. @unhead/vue) on fresh installs (Cloudflare Pages / CI). Without this,
# pnpm's strict symlinked layout breaks `nuxt generate` prerendering with
# "Cannot find package '@unhead/vue' imported from .nuxt/prerender/.../server.mjs".
shamefully-hoist=true
